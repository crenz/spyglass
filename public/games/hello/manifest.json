{
  "id": "hello",
  "version": 4,
  "title": "Hello, Spyglass",
  "startScene": "title",
  "scenes": [
    {
      "id": "title",
      "kind": "splash",
      "title": "Title",
      "image": "images/title.png",
      "advance": { "kind": "click" },
      "onAdvance": { "gotoSceneId": "intro_video" }
    },
    {
      "id": "intro_video",
      "kind": "cutscene",
      "title": "Intro",
      "video": "videos/intro.mp4",
      "captions": "videos/intro.vtt",
      "skipPolicy": { "kind": "always" },
      "onEnd": { "gotoSceneId": "scene_1" }
    },
    {
      "id": "scene_1",
      "kind": "hidden_object",
      "title": "The Library",
      "image": {
        "src": "images/scene-1.png",
        "width": 1024,
        "height": 768
      },
      "regions": [
        {
          "id": "t_key",
          "kind": "target",
          "shape": "rect",
          "rect": { "x": 80, "y": 180, "w": 80, "h": 80 }
        },
        {
          "id": "t_book",
          "kind": "target",
          "shape": "polygon",
          "polygon": {
            "points": [
              [420, 260],
              [510, 270],
              [505, 340],
              [415, 335]
            ]
          }
        },
        {
          "id": "t_cup",
          "kind": "target",
          "shape": "circle",
          "circle": { "cx": 760, "cy": 180, "r": 42 }
        },
        {
          "id": "r_key",
          "kind": "reference",
          "shape": "rect",
          "rect": { "x": 100, "y": 620, "w": 80, "h": 80 }
        },
        {
          "id": "r_book",
          "kind": "reference",
          "shape": "rect",
          "rect": { "x": 320, "y": 620, "w": 80, "h": 80 }
        },
        {
          "id": "r_cup",
          "kind": "reference",
          "shape": "rect",
          "rect": { "x": 540, "y": 620, "w": 80, "h": 80 }
        },
        {
          "id": "hint_btn",
          "kind": "hint",
          "shape": "rect",
          "rect": { "x": 900, "y": 640, "w": 90, "h": 60 }
        }
      ],
      "objectives": [
        {
          "id": "key",
          "label": "Brass key",
          "targetRegionId": "t_key",
          "referenceRegionId": "r_key"
        },
        {
          "id": "book",
          "label": "Leather book",
          "targetRegionId": "t_book",
          "referenceRegionId": "r_book"
        },
        {
          "id": "cup",
          "label": "Porcelain cup",
          "targetRegionId": "t_cup",
          "referenceRegionId": "r_cup"
        }
      ],
      "onComplete": { "gotoSceneId": "intro" }
    },
    {
      "id": "intro",
      "kind": "splash",
      "title": "Intro",
      "image": "images/intro.png",
      "advance": { "kind": "key" },
      "onAdvance": { "gotoSceneId": null }
    }
  ]
}
